{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Nico",
    "patterns": [
        {"include": "#comments"},
        {"include": "#strings"},
        {"include": "#numbers"},
        {"include": "#variables"},
        {"include": "#keywords"},
        {"include": "#types"},
        {"include": "#functions"},
        {"include": "#constants"}
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.nico",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.nico",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.nico",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.nico",
                    "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.nico",
                    "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.nico",
                    "match": "\\b(PROGRAMA|FINAL|BLOQUE|PRINCIPAL|FIN|SI|ENTONCES|SINO|SINOSI|MIENTRAS|HACER|PARA|DESDE|HASTA|PASO|SEGUN|CASO|FUNCION|SUBPROGRAMA|RETORNAR|LLAMAR|A|VARIABLE|CONSTANTE|DECLARAR|CALCULAR|EN|ASIGNAR|RESULTADO|O|Y|IGUAL|DIFERENTE|MAYOR|MENOR|MAYOR_IGUAL|MENOR_IGUAL|ENTERA|DECIMAL|TEXTO|LOGICA|CARACTER|ARCHIVO|LISTA|MATRIZ|EXTENSO|ESCRIBIR|MOSTRAR|LEER|LEERCARACTER|LEERHASTA|LEERTECLA|TECLAMANTENIDA|FECHAACTUAL|HORAACTUAL|TIEMPOMS|MICROS|MILISEGUNDOS|SEGUNDOS|MINUTOS|ESPERAR|LIMPIARPANTALLA|CLS|CLEAR|COLORTEXTO|COLORFONDO|RESETCOLOR|RESETTEXTO|TEXTONEGRITA|TEXTOCURSIVA|TEXTOSUBRAYADO|POSICIONAR|CURSOR|MOSTRARCURSOR|OCULTARCURSOR|DIBUJARLINEA|DIBUJARCIRCULO|RELLENARRECTANGULO|COLISIONRECTANGULOS|ANCHOTERMINAL|ALTOTERMINAL|CONFIGURARPIN|ESTADOPIN|LEERPIN|GENERARPWM|DETENERPWM|ACTIVARBIT|DESACTIVARBIT|LEERBIT|CONTARBITS|DESPLAZARDERECHA|DESPLAZARIZQUIERDA|ROTARDERECHA|ROTARIZQUIERDA|INVERTIRBYTES|BITO|BITY|BITXOR|BITNO|ABRIRARCHIVO|CERRARARCHIVO|LEERARCHIVO|ESCRIBIRARCHIVO|USARARCHIVO|FINARCHIVO|CONECTARBD|CERRARBD|CONSULTARBD|CERRARCONSULTABD|EJECUTARBD|INICIARTRANSACCION|CONFIRMARTRANSACCION|DESHACERTRANSACCION|INICIARSERVER|DETENERSERVER|DOSALAX|INCLUIR|SISTEMA|AGREGAR|REALIZAR|SALTAR|CORTE|ENTRADA|SALIDA|LECTURA|LECTOESCRITURA|ESCRITURA|PULLUP|PULLDOWN|DEFECTO|ARRIBA|ABAJO|IZQUIERDA|DERECHA|POR|SIGMOIDE|COSENO|SENO|TANGENTE|ARCOCOSENO|ARCOSENO|ARCOTANGENTE|RAIZ|RAIZCUBICA|RAIZDEUNMEDIO|LOGARITMO|LOGNATURAL|LOGNATURALDE|LOGBASE|POTENCIA|POTENCIA_FN|ABSOLUTO|SIGNO|REDONDEAR|QUITARDECIMAL|ALEATORIO|ALEATORIOSINSIGNO|MAXIMO|MINIMO|MOD|MODULO|MODULO_FN|NUMEROPI|NUMEROEULER|COPIARTEXTO|CONCATENARTEXTO|LONGITUDTEXTO|BUSCARTEXTO|BUSCARCARACTER|COMPARARTEXTO|MAYUSCULAS|MINUSCULAS|RECORTARTEXTO|REEMPLAZARTEXTO|REPETIRTEXTO|EXTRAERTEXTO|INVERTIRTEXTO|DIVIDIRTEXTO|ENTEROATEXTO|DECIMALATEXTO|CARACTERATEXTO|TEXTOAENTERO|TEXTOADECIMAL|TEXTOACARACTER|LONGITUDLISTA|SALTO|SIN_SALTO)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "keyword.control.nico",
                    "match": "\\b(ENTERA|DECIMAL|TEXTO|LOGICA|CARACTER|ARCHIVO|LISTA|MATRIZ|EXTENSO)\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "keyword.control.nico",
                    "match": "\\b(SIGMOIDE|COSENO|SENO|TANGENTE|ARCOCOSENO|ARCOSENO|ARCOTANGENTE|RAIZ|RAIZCUBICA|RAIZDEUNMEDIO|LOGARITMO|LOGNATURAL|LOGNATURALDE|LOGBASE|POTENCIA|POTENCIA_FN|ABSOLUTO|SIGNO|REDONDEAR|QUITARDECIMAL|ALEATORIO|ALEATORIOSINSIGNO|MAXIMO|MINIMO|MOD|MODULO|MODULO_FN|NUMEROPI|NUMEROEULER|COPIARTEXTO|CONCATENARTEXTO|LONGITUDTEXTO|BUSCARTEXTO|BUSCARCARACTER|COMPARARTEXTO|MAYUSCULAS|MINUSCULAS|RECORTARTEXTO|REEMPLAZARTEXTO|REPETIRTEXTO|EXTRAERTEXTO|INVERTIRTEXTO|DIVIDIRTEXTO|ENTEROATEXTO|DECIMALATEXTO|CARACTERATEXTO|TEXTOAENTERO|TEXTOADECIMAL|TEXTOACARACTER|LONGITUDLISTA|ESCRIBIR|MOSTRAR|LEER|LEERCARACTER|LEERHASTA|LEERTECLA|TECLAMANTENIDA|FECHAACTUAL|HORAACTUAL|TIEMPOMS|MICROS|MILISEGUNDOS|SEGUNDOS|MINUTOS|ESPERAR|LIMPIARPANTALLA|CLS|CLEAR|COLORTEXTO|COLORFONDO|RESETCOLOR|RESETTEXTO|TEXTONEGRITA|TEXTOCURSIVA|TEXTOSUBRAYADO|POSICIONAR|CURSOR|MOSTRARCURSOR|OCULTARCURSOR|DIBUJARLINEA|DIBUJARCIRCULO|RELLENARRECTANGULO|COLISIONRECTANGULOS|ANCHOTERMINAL|ALTOTERMINAL|CONFIGURARPIN|ESTADOPIN|LEERPIN|GENERARPWM|DETENERPWM|ACTIVARBIT|DESACTIVARBIT|LEERBIT|CONTARBITS|DESPLAZARDERECHA|DESPLAZARIZQUIERDA|ROTARDERECHA|ROTARIZQUIERDA|INVERTIRBYTES|BITO|BITY|BITXOR|BITNO|ABRIRARCHIVO|CERRARARCHIVO|LEERARCHIVO|ESCRIBIRARCHIVO|USARARCHIVO|FINARCHIVO|CONECTARBD|CERRARBD|CONSULTARBD|CERRARCONSULTABD|EJECUTARBD|INICIARTRANSACCION|CONFIRMARTRANSACCION|DESHACERTRANSACCION|INICIARSERVER|DETENERSERVER|DOSALAX|INCLUIR|SISTEMA|AGREGAR|REALIZAR|SALTAR|CORTE|ENTRADA|SALIDA|LECTURA|LECTOESCRITURA|ESCRITURA|PULLUP|PULLDOWN|DEFECTO|ARRIBA|ABAJO|IZQUIERDA|DERECHA|POR)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "keyword.control.nico",
                    "match": "\\b(VERDADERO|FALSO|PI|NO|S|SALTO|SIN_SALTO)\\b"
                }
            ]
        }
    },
    "scopeName": "source.nico"
}
