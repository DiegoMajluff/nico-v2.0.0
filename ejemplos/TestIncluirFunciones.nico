PROGRAMA funciones
FUNCION ENTERA sumar($a, $b)
    //VARIABLE ENTERA $suma = 0
    //CALCULAR EN $suma = $a + $b
    RETORNAR $a + $b
FIN FUNCION
FUNCION ENTERA multiplicar($c, $d)
    //VARIABLE ENTERA $multiplicar = 0
    //CALCULAR EN $multiplicar = $c * $d
    RETORNAR $c * $d
FIN FUNCION
//BLOQUE PRINCIPAL
//FIN PRINCIPAL
FINAL