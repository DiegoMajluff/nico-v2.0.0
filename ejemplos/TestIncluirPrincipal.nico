PROGRAMA include_princ
INCLUIR "TestIncludeFunciones.nico"
BLOQUE PRINCIPAL
    VARIABLE ENTERA $funcion1 = 0, $funcion2 = 0
    ASIGNAR EN $funcion1 = suma(20, 30)
    MOSTRAR("El resultado de la suma es de: $funcion1") SALTO

    ASIGNAR EN $funcion2 = multiplicar(6, 8)
    MOSTRAR("El resultado de la multiplicación es de: $funcion2") SALTO
FIN PRINCIPAL
FINAL