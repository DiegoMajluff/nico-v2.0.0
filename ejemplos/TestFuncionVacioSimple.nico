PROGRAMA TestFuncionVacioSimple

FUNCION SALUDAR($nombre)
    MOSTRAR("Hola ")
    MOSTRAR($nombre)
    MOSTRAR("!") SALTO
FIN FUNCION

FUNCION ENTERA sumar($a, $b)
    CALCULAR EN $op = $a + $b
    MOSTRAR("$op") SALTO
    RETORNAR $op
FIN FUNCION

BLOQUE PRINCIPAL
    VARIABLE ENTERA $x = 1, $y
    SI($x IGUAL 1) ENTONCES
        LLAMAR A SALUDAR("Diego")
        ASIGNAR EN $y = sumar(2, 3)
    FIN SI
FIN PRINCIPAL
FINAL
