PROGRAMA TestTraerSimple
BLOQUE PRINCIPAL
    CONECTARBD("test_simple.db")
    EJECUTARBD("CREATE TABLE IF NOT EXISTS prueba (id INTEGER, valor TEXT)")
    EJECUTARBD("INSERT INTO prueba VALUES (1, 'hola')")
    
    // Test mínimo
    CONSULTARBD("SELECT id, valor FROM prueba ", 1)
    MIENTRAS(SIGUIENTEFILABD()) HACER
        ESCRIBIR("$BDCOL1 - $BDCOL2") SALTO
    FIN MIENTRAS
    CERRARCONSULTABD
    CERRARBD
FIN PRINCIPAL
FINAL
